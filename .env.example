# Copia in .env (root) e adatta i valori.

# --- Backend (FastAPI) ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/amazon_listing
API_HOST=0.0.0.0
API_PORT=8000
# Deploy Railway: assicurati di eseguire "alembic upgrade head" prima di avviare uvicorn.
# Supporta sia CSV sia JSON array:
# CSV (consigliato in Railway):
CORS_ORIGINS=https://frontend-production-cbba.up.railway.app,http://localhost:3000,http://127.0.0.1:3000
# JSON array (alternativa):
# CORS_ORIGINS=["https://frontend-production-cbba.up.railway.app","http://localhost:3000","http://127.0.0.1:3000"]

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
